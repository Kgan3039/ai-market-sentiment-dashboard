# Backend API Configuration
# Copy this file to .env and fill in actual values

# App Settings
APP_NAME=AI Market Sentiment API
APP_VERSION=0.1.0
DEBUG=False

# Server Settings
HOST=0.0.0.0
PORT=8000

# External Services (update when services are live)
NLP_SERVICE_URL=http://localhost:8001
PREDICTION_SERVICE_URL=http://localhost:8002
DATA_SERVICE_URL=http://localhost:8003

# Reddit API Credentials
# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=your_user_agent_here

# Gemini API (ai/summarization.py theme summaries, issue #65)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
